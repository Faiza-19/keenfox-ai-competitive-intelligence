# KeenFox Competitive Intelligence System - Environment Configuration
# Copy this to .env and fill in your values

# Required: Anthropic API Key
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: SerpAPI for enhanced web search (free tier available)
SERPAPI_KEY=your_serpapi_key_here

# System Configuration
MAX_CONCURRENT_REQUESTS=3
REQUEST_DELAY_MS=2000
MAX_RETRIES=3
RETRY_DELAY_MS=5000

# Output Configuration
OUTPUT_DIR=./outputs
REPORT_FORMAT=markdown   # markdown | json | both

# Scraping Configuration
SCRAPE_TIMEOUT_MS=15000
USER_AGENT=Mozilla/5.0 (compatible; KeenFoxBot/1.0; Research purposes)

# Dashboard Configuration
DASHBOARD_PORT=3000
DASHBOARD_HOST=localhost
